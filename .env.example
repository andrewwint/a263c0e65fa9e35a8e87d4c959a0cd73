# AWS credentials are resolved by boto3's default credential chain.
# No API keys here — use `aws configure` (IAM user) or `aws sso login` locally.
# In Lambda, the function's execution role provides credentials automatically.

AWS_PROFILE=default
AWS_REGION=us-east-1

# Optional overrides (leave unset to use PLAN.md defaults)
# BEDROCK_ENRICH_MODEL=openai.gpt-oss-20b-1:0
# BEDROCK_AGENT_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
